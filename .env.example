# =============================================================================
# CyberNest SIEM + SOAR Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and modify values as needed.
# All variables have sensible defaults in docker-compose.yml.
# =============================================================================

# ─── General ────────────────────────────────────────────────
TZ=UTC
LOG_LEVEL=INFO

# ─── PostgreSQL ─────────────────────────────────────────────
POSTGRES_PASSWORD=CyberNest2025!

# ─── Security ──────────────────────────────────────────────
JWT_SECRET=supersecretjwtkey2025changeme
AGENT_SECRET_KEY=cybernest-agent-secret-2025

# ─── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost

# ─── Slack Notifications ───────────────────────────────────
SLACK_WEBHOOK_URL=

# ─── Email / SMTP ──────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── PagerDuty ─────────────────────────────────────────────
PAGERDUTY_API_KEY=

# ─── Threat Intelligence API Keys ──────────────────────────
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
SHODAN_API_KEY=
OTX_API_KEY=

# ─── JIRA Integration ─────────────────────────────────────
JIRA_URL=
JIRA_USER=
JIRA_TOKEN=

# ─── Microsoft Teams ──────────────────────────────────────
TEAMS_WEBHOOK_URL=
