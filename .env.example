###############################################################################
# CyberNest — Environment Configuration
###############################################################################

# Deployment
CYBERNEST_ENV=development

# PostgreSQL
POSTGRES_DB=cybernest
POSTGRES_USER=cybernest
POSTGRES_PASSWORD=cybernest_secret

# JWT Authentication
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-64
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Redis
REDIS_URL=redis://redis:6379/0

# Notification Channels
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SLACK_WEBHOOK_URL=
PAGERDUTY_API_KEY=
TEAMS_WEBHOOK_URL=

# Threat Intelligence API Keys
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
SHODAN_API_KEY=
OTX_API_KEY=

# Ticketing Integration
JIRA_URL=
JIRA_USER=
JIRA_TOKEN=

# GeoIP (MaxMind)
MAXMIND_LICENSE_KEY=
