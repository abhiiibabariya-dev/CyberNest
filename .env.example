# =============================================================================
# CyberNest SIEM + SOAR Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and modify values as needed.
# All variables have sensible defaults in docker-compose.yml.
# =============================================================================

# ---------- General ----------
TZ=UTC
LOG_LEVEL=INFO

# ---------- PostgreSQL ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cybernest
POSTGRES_USER=cybernest
POSTGRES_PASSWORD=CyberNest2025!

# ---------- Kafka ----------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_EXTERNAL_PORT=9093
KAFKA_LOG_RETENTION_HOURS=168
KAFKA_LOG_RETENTION_BYTES=1073741824
KAFKA_MESSAGE_MAX_BYTES=10485760
KAFKA_TOPIC_RETENTION_MS=604800000

# ---------- Zookeeper ----------
ZOOKEEPER_CLIENT_PORT=2181

# ---------- Elasticsearch ----------
ELASTICSEARCH_URL=http://elasticsearch:9200
ES_HEAP_SIZE=1g
ES_CLUSTER_NAME=cybernest
ES_INDEX_PREFIX=cybernest
ES_INDEX_SHARDS=1
ES_INDEX_REPLICAS=0

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0
REDIS_MAXMEMORY=512mb

# ---------- Manager / API ----------
MANAGER_PORT=5000
FLASK_ENV=production
SECRET_KEY=change-me-in-production-cybernest-2025
JWT_SECRET_KEY=jwt-change-me-cybernest-2025
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=86400
CORS_ORIGINS=*

# ---------- Syslog Receiver ----------
SYSLOG_UDP_PORT=514
SYSLOG_TCP_PORT=601

# ---------- Parser ----------
PARSER_BATCH_SIZE=100
PARSER_BATCH_TIMEOUT_MS=5000

# ---------- Correlator ----------
CORRELATION_WINDOW_SECONDS=300
CORRELATION_BATCH_SIZE=50

# ---------- Alert Manager ----------
ALERT_DEDUP_WINDOW_SECONDS=300
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SLACK_WEBHOOK_URL=

# ---------- SOAR ----------
SOAR_MAX_CONCURRENT_PLAYBOOKS=10
SOAR_STEP_TIMEOUT_SECONDS=300

# ---------- Indexer ----------
INDEXER_BATCH_SIZE=500
INDEXER_FLUSH_INTERVAL_SECONDS=5

# ---------- Threat Intelligence ----------
THREAT_INTEL_FETCH_INTERVAL_HOURS=6
ABUSE_IPDB_API_KEY=
VIRUSTOTAL_API_KEY=
OTX_API_KEY=

# ---------- Dashboard ----------
DASHBOARD_PORT=3000
REACT_APP_API_URL=/api
REACT_APP_WS_URL=/ws

# ---------- Nginx ----------
HTTP_PORT=80
HTTPS_PORT=443
